# ~/.config/zsh/secrets.zsh
#
# Bitwarden integration, SSH agent setup, and SSH key auto-loading
# MUST be sourced (not executed) to set BW_SESSION and SSH_AUTH_SOCK
# Only loaded for interactive shells (loader handles this)

_BW_SESSION_FILE="${HOME}/.config/zsh/.bw-session"

# ============================================================================
# Bitwarden Helper Functions
# ============================================================================

bwunlock() {
    if [[ -n "$BW_SESSION" ]]; then
        if bw status 2>/dev/null | jq -e '.status == "unlocked"' > /dev/null 2>&1; then
            echo "Bitwarden already unlocked"
            return 0
        fi
        unset BW_SESSION
    fi

    local bw_status
    bw_status=$(bw status 2>/dev/null | jq -r '.status')

    if [[ "$bw_status" == "unauthenticated" ]]; then
        echo "Logging in to Bitwarden..."
        bw login
        bw_status=$(bw status 2>/dev/null | jq -r '.status')
    fi

    if [[ "$bw_status" == "locked" ]]; then
        while true; do
            echo "Unlocking Bitwarden vault..."
            export BW_SESSION=$(bw unlock --raw)

            bw_status=$(bw status 2>/dev/null | jq -r '.status')
            if [[ "$bw_status" == "unlocked" ]]; then
                echo "Syncing Bitwarden vault..."
                bw sync
                printf 'export BW_SESSION=%q\n' "$BW_SESSION" > "$_BW_SESSION_FILE"
                chmod 600 "$_BW_SESSION_FILE"
                break
            fi

            echo -n "Unlock failed. Try again? (Y/n): "
            read -r response
            if [[ "$response" =~ ^[Nn]$ ]]; then
                echo "Bitwarden unlock cancelled"
                return 1
            fi
        done
    fi
}

bwlock() {
    rm -f "$_BW_SESSION_FILE"
    unset BW_SESSION
    echo "Bitwarden session cleared"
}

# Wrapper for chezmoi that ensures Bitwarden is unlocked
chezmoi() {
    case "$1" in
        apply|update|init)
            bwunlock
            ;;
    esac
    command chezmoi "$@"
}

# ============================================================================
# Bitwarden Session Restore on Startup
# ============================================================================

if [[ -z "$BW_SESSION" ]]; then
    if [[ -f "$_BW_SESSION_FILE" ]]; then
        source "$_BW_SESSION_FILE"

        if ! bw status 2>/dev/null | jq -e '.status == "unlocked"' > /dev/null 2>&1; then
            echo "Stored Bitwarden session expired, clearing."
            rm -f "$_BW_SESSION_FILE"
            unset BW_SESSION
        fi
    fi

    if [[ -z "$BW_SESSION" ]]; then
        BW_STATUS=$(bw status 2>/dev/null | jq -r '.status')
        if [[ "$BW_STATUS" == "locked" ]] || [[ "$BW_STATUS" == "unauthenticated" ]]; then
            echo -n "Bitwarden is locked. Unlock now? (Y/n): "
            read -r response
            if [[ ! "$response" =~ ^[Nn]$ ]]; then
                bwunlock
            fi
        fi
    fi
fi

# ============================================================================
# SSH Agent Configuration (Linux/WSL only)
# ============================================================================

# On macOS, the Bitwarden desktop app serves SSH keys via its own socket
# with biometric auth — no ssh-agent management or ssh-add needed.
if [[ "$(uname)" != "Darwin" ]]; then
    if [ -z "$SSH_AUTH_SOCK" ]; then
        if [ -f "$HOME/.ssh/ssh-agent" ]; then
            eval `command cat $HOME/.ssh/ssh-agent`
        fi
    fi

    # ssh-add -l exit codes: 0=keys listed, 1=no keys but agent OK, 2=can't connect
    ssh-add -l &>/dev/null
    SSH_AGENT_STATUS=$?

    if [ $SSH_AGENT_STATUS -eq 2 ]; then
        ssh-agent -s > $HOME/.ssh/ssh-agent
        eval `command cat $HOME/.ssh/ssh-agent`
    fi

    if [ -n "$SSH_AUTH_SOCK" ] && [ -n "$BW_SESSION" ]; then
        SSH_KEY_PATH="$HOME/.ssh/id_ed25519"
        if [ -f "$SSH_KEY_PATH" ]; then
            KEY_FINGERPRINT=$(ssh-keygen -lf "$SSH_KEY_PATH" 2>/dev/null | awk '{print $2}')

            if ! ssh-add -l 2>/dev/null | grep -q "$KEY_FINGERPRINT"; then
                SSH_PASSPHRASE='{{ (bitwardenFields "item" "SSH Key - GitHub").passkey.value }}'

                SSH_KEY_PATH="$SSH_KEY_PATH" SSH_PASSPHRASE="$SSH_PASSPHRASE" expect >/dev/null 2>&1 <<'EXPECT_EOF'
log_user 0
set timeout 10
spawn ssh-add $env(SSH_KEY_PATH)
expect {
    -re "Enter passphrase.*:" {
        send "$env(SSH_PASSPHRASE)\r"
        exp_continue
    }
    "Identity added" {
        exit 0
    }
    "Bad passphrase" {
        exit 2
    }
    timeout {
        exit 3
    }
    eof
}
EXPECT_EOF

                EXPECT_EXIT=$?
                if [ $EXPECT_EXIT -ne 0 ]; then
                    echo "Warning: Failed to auto-load SSH key (exit code: $EXPECT_EXIT)" >&2
                fi
            fi
        fi
    elif [ -n "$SSH_AUTH_SOCK" ] && [ -z "$BW_SESSION" ]; then
        echo "Note: SSH agent running, but SSH key not auto-loaded (Bitwarden locked)"
    fi
fi
