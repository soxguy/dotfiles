# ~/.config/zsh/aliases.zsh
#
# Command aliases for interactive shell use
# Only loaded for interactive shells (loader handles this)

# Better cat with syntax highlighting
# Ubuntu apt installs bat as 'batcat'; macOS Homebrew installs as 'bat'
if command -v batcat &>/dev/null; then
    alias bat='batcat'
    alias cat='batcat'
elif command -v bat &>/dev/null; then
    alias cat='bat'
fi

export BAT_THEME="Nord"

# Modern ls replacement
# eza (Ubuntu 24.04+, macOS) is a fork of exa (Ubuntu <24.04) with identical flags;
# detect whichever is installed at runtime.
if command -v eza &>/dev/null; then
    _EZA=eza
elif command -v exa &>/dev/null; then
    _EZA=exa
fi
if [[ -n "$_EZA" ]]; then
    alias l="$_EZA --icons --group-directories-first --git --header"
    alias ls="$_EZA --icons --group-directories-first --git --header -1"
    alias ll="$_EZA --icons --group-directories-first --git --long --header"
    alias la="$_EZA --icons --group-directories-first --git --long --all --header"
fi
unset _EZA

# Quick navigation
alias cdr='cd ~/repos'
{{ if .isWorkMachine -}}
alias cdrw='cd ~/repos/work; ll'
alias cdrp='cd ~/repos/personal; ll'

# Cortex CLI completion (generated by cortex, disable via /settings in cortex)
[[ -s ~/.zsh/completions/cortex.zsh ]] && source ~/.zsh/completions/cortex.zsh
{{ end -}}
alias sudo='sudo '

# Alias Nala for package management (Linux only)
if (( $+commands[nala] )); then
  alias apt='nala'
fi
