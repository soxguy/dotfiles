# ~/.config/zsh/exports.zsh
#
# Environment variable exports
# Contains secrets retrieved from Bitwarden at chezmoi apply time
# Machine type: {{ if .isWorkMachine }}work{{ else }}personal{{ end }}

# Bitwarden item name for local account sudo password
# Pattern: ubuntu-USERNAME (e.g., ubuntu-dawheat, ubuntu-foo)
# Override by setting BW_LOCAL_ACCT in ~/.config/zsh/local.zsh before this file loads
: ${BW_LOCAL_ACCT:="ubuntu-{{ .chezmoi.username }}"}
export BW_LOCAL_ACCT

{{/* Never export lab-wide infrastructure credentials on a CI-managed dev/agent box.
     BWS_ACCESS_TOKEN unlocks the whole Bitwarden Secrets Manager project (vCenter,
     Terraform Cloud, the build SSH private key, Cloudflare, iDRAC). A box that runs
     AI agents has no need to deploy infrastructure — that is the CI runner's job —
     so it must not carry ambient credentials to the entire lab. */}}
{{- $isDevBox := false }}
{{- if hasKey . "isDevBox" }}{{- $isDevBox = .isDevBox }}{{- end }}
{{- $devBoxDeny := list "BWS_ACCESS_TOKEN" }}

# Shared environment variables (all machines)
{{- range $key, $field := (bitwardenFields "item" "chezmoi-env-shared") }}
{{- if and $isDevBox (has $key $devBoxDeny) }}
# {{ $key }}: withheld on this dev/agent box (lab-wide infra credential)
{{- else if hasSuffix "_HOME_PATH" $key }}
export {{ trimSuffix "_HOME_PATH" $key }}={{ printf "%s/%s" $.chezmoi.homeDir $field.value | quote }}
{{- else }}
export {{ $key }}={{ $field.value | quote }}
{{- end }}
{{- end }}

# Machine-specific environment variables
{{- if .isWorkMachine }}
{{- range $key, $field := (bitwardenFields "item" "chezmoi-env-work") }}
{{- if hasSuffix "_HOME_PATH" $key }}
export {{ trimSuffix "_HOME_PATH" $key }}={{ printf "%s/%s" $.chezmoi.homeDir $field.value | quote }}
{{- else }}
export {{ $key }}={{ $field.value | quote }}
{{- end }}
{{- end }}

# Work cert paths (standard locations, not secrets)
export ZSCALER_CERT="{{ .chezmoi.homeDir }}/.certs/zscaler_root.crt"
export BUNDLED_CERT="{{ .chezmoi.homeDir }}/.certs/combined_ca_bundle.pem"
export AWS_CA_BUNDLE="{{ .chezmoi.homeDir }}/.certs/combined-ca-bundle.crt"
export NODE_EXTRA_CA_CERTS="$ZSCALER_CERT"
export REQUESTS_CA_BUNDLE="$BUNDLED_CERT"
{{- else }}
{{- range $key, $field := (bitwardenFields "item" "chezmoi-env-personal") }}
{{- if and $isDevBox (has $key $devBoxDeny) }}
# {{ $key }}: withheld on this dev/agent box (lab-wide infra credential)
{{- else if hasSuffix "_HOME_PATH" $key }}
export {{ trimSuffix "_HOME_PATH" $key }}={{ printf "%s/%s" $.chezmoi.homeDir $field.value | quote }}
{{- else }}
export {{ $key }}={{ $field.value | quote }}
{{- end }}
{{- end }}
{{- end }}

# AI client key mappings (derived from LiteLLM vars)
[[ -n "${LITELLM_API_KEY:-}" ]] && export ANTHROPIC_AUTH_TOKEN="$LITELLM_API_KEY"
[[ -n "${LITELLM_API_GATEWAY:-}" ]] && export ANTHROPIC_BASE_URL="$LITELLM_API_GATEWAY"

# Claude Plugin — uses management key so it can call /key/info (regular key is route-restricted)
[[ -n "${LITELLM_API_MGMT_KEY:-}" ]] && export LITELLM_PROXY_API_KEY="$LITELLM_API_MGMT_KEY"
[[ -n "${LITELLM_API_GATEWAY:-}" ]] && export LITELLM_PROXY_URL="$LITELLM_API_GATEWAY"
