{{- $sub := (bitwardenFields "item" "chezmoi-env-shared").SECOND_BRAIN_SUBDIR.value -}}
{{- if .isWorkMachine -}}
{{- $work := bitwardenFields "item" "chezmoi-env-work" -}}
{{- if $work.SECOND_BRAIN_SUBDIR -}}{{- $sub = $work.SECOND_BRAIN_SUBDIR.value -}}{{- end -}}
{{- else -}}
{{- $personal := bitwardenFields "item" "chezmoi-env-personal" -}}
{{- if $personal.SECOND_BRAIN_SUBDIR -}}{{- $sub = $personal.SECOND_BRAIN_SUBDIR.value -}}{{- end -}}
{{- end -}}
{
  "$schema": "https://opencode.ai/config.json",
  "instructions": "{{ .chezmoi.homeDir }}/{{ $sub }}/AGENTS.md",
  "provider": {
    "llama-local": {
      "name": "Llama.cpp (RTX 3090)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://llm.home.wheatweb.com/v1"
      },
      "models": {
        "gemma-4-26b": {
          "name": "Gemma 4 26B MoE"
        }
      }
    }
  }
}
